{
  "name": "rc-mcp",
  "version": "0.1.0",
  "description": "Minimal MCP Server Generator for Rocket.Chat — generate production-ready MCP servers with only the APIs you need",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "rc-mcp": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/providers dist/",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "rocketchat",
    "model-context-protocol",
    "ai",
    "code-generation",
    "gemini-cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "handlebars": "^4.7.8",
    "ora": "^8.1.1",
    "yaml": "^2.6.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
