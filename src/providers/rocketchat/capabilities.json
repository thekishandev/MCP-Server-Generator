{
    "send-message": {
        "description": "Send messages to Rocket.Chat channels, groups, or direct messages",
        "endpoints": [
            "/api/v1/login",
            "/api/v1/chat.postMessage"
        ],
        "auth": true
    },
    "read-messages": {
        "description": "Read message history and search messages in channels",
        "endpoints": [
            "/api/v1/login",
            "/api/v1/channels.history",
            "/api/v1/chat.search",
            "/api/v1/chat.getMessage"
        ],
        "auth": true
    },
    "manage-channels": {
        "description": "Create, archive, rename, and configure channels",
        "endpoints": [
            "/api/v1/login",
            "/api/v1/channels.create",
            "/api/v1/channels.archive",
            "/api/v1/channels.unarchive",
            "/api/v1/channels.rename",
            "/api/v1/channels.setDescription",
            "/api/v1/channels.info",
            "/api/v1/channels.list"
        ],
        "auth": true
    },
    "manage-users": {
        "description": "Create, update, delete, and list users",
        "endpoints": [
            "/api/v1/login",
            "/api/v1/users.create",
            "/api/v1/users.update",
            "/api/v1/users.delete",
            "/api/v1/users.info",
            "/api/v1/users.list"
        ],
        "auth": true
    },
    "file-upload": {
        "description": "Upload files and retrieve file information",
        "endpoints": [
            "/api/v1/login",
            "/api/v1/rooms.upload",
            "/api/v1/channels.files"
        ],
        "auth": true
    }
}