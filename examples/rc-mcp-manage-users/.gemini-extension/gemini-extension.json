{
  "name": "rc-mcp-manage-users",
  "version": "1.0.0",
  "description": "Minimal MCP server for Rocket.Chat: manage-users",
  "mcpServers": {
    "rc-mcp-manage-users": {
      "command": "node",
      "args": [
        "./dist/server.js"
      ],
      "env": {
        "RC_URL": "${RC_URL}",
        "RC_USER": "${RC_USER}",
        "RC_PASSWORD": "${RC_PASSWORD}"
      }
    }
  }
}